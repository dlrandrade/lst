generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TaskStatus {
  ACTIVE
  ARCHIVED
}

enum BookStatus {
  TO_READ
  READING
  FINISHED
  ABANDONED
}

enum MovieStatus {
  TO_WATCH
  WATCHING
  WATCHED
  ABANDONED
}

enum AppointmentStatus {
  SCHEDULED
  DONE
  CANCELED
}

enum ReminderStatus {
  PENDING
  DONE
  CANCELED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum MedicationFrequencyType {
  DAILY
  WEEKLY
  CUSTOM
  AS_NEEDED
}

enum ExamStatus {
  PLANNED
  SCHEDULED
  DONE
  REVIEWED
}

model User {
  id                 String                @id @default(cuid())
  email              String                @unique
  passwordHash       String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  profile            Profile?
  tasks              Task[]
  taskLogs           TaskLog[]
  workoutPlans       WorkoutPlan[]
  workoutLogs        WorkoutLog[]
  mealPlans          MealPlan[]
  mealLogs           MealLog[]
  books              Book[]
  bookLogs           BookLog[]
  movies             Movie[]
  movieLogs          MovieLog[]
  waterGoal          WaterGoal?
  waterLogs          WaterLog[]
  appointments       Appointment[]
  reminders          Reminder[]
  medications        Medication[]
  medicationLogs     MedicationLog[]
  exams              Exam[]
  examLogs           ExamLog[]
  examFiles          ExamFile[]
}

model Profile {
  id              String    @id @default(cuid())
  userId          String    @unique
  fullName        String
  timezone        String    @default("America/Recife")
  dailyWaterGoal  Int?      @default(2000)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id              String      @id @default(cuid())
  userId          String
  title           String
  description     String?
  isRecurring     Boolean     @default(false)
  recurrenceRule  String?
  status          TaskStatus  @default(ACTIVE)
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs            TaskLog[]

  @@index([userId, status])
}

model TaskLog {
  id              String    @id @default(cuid())
  userId          String
  taskId          String
  occurredOn      DateTime
  completed       Boolean   @default(true)
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, occurredOn])
  @@index([userId, occurredOn])
}

model WorkoutPlan {
  id              String        @id @default(cuid())
  userId          String
  name            String
  description     String?
  startsAt        DateTime?
  endsAt          DateTime?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  days            WorkoutDay[]

  @@index([userId, isActive])
}

model WorkoutDay {
  id              String             @id @default(cuid())
  workoutPlanId   String
  weekDay         Int
  title           String?
  sortOrder       Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  workoutPlan     WorkoutPlan        @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  exercises       WorkoutExercise[]

  @@unique([workoutPlanId, weekDay])
}

model WorkoutExercise {
  id              String        @id @default(cuid())
  workoutDayId    String
  name            String
  notes           String?
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  workoutDay      WorkoutDay    @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  logs            WorkoutLog[]
}

model WorkoutLog {
  id                String           @id @default(cuid())
  userId            String
  workoutExerciseId String
  occurredOn        DateTime
  completed         Boolean          @default(true)
  notes             String?
  createdAt         DateTime         @default(now())
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutExercise   WorkoutExercise  @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@unique([workoutExerciseId, occurredOn])
  @@index([userId, occurredOn])
}

model MealPlan {
  id              String         @id @default(cuid())
  userId          String
  name            String
  referenceMonth  Int?
  referenceYear   Int?
  startsAt        DateTime?
  endsAt          DateTime?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections        MealSection[]

  @@index([userId, isActive])
}

model MealSection {
  id              String       @id @default(cuid())
  mealPlanId      String
  title           String
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  mealPlan        MealPlan     @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  items           MealItem[]
  logs            MealLog[]
}

model MealItem {
  id              String       @id @default(cuid())
  mealSectionId   String
  description     String
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  mealSection     MealSection  @relation(fields: [mealSectionId], references: [id], onDelete: Cascade)
}

model MealLog {
  id              String       @id @default(cuid())
  userId          String
  mealSectionId   String
  occurredOn      DateTime
  completed       Boolean      @default(true)
  notes           String?
  createdAt       DateTime     @default(now())
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealSection     MealSection  @relation(fields: [mealSectionId], references: [id], onDelete: Cascade)

  @@unique([mealSectionId, occurredOn])
  @@index([userId, occurredOn])
}

model Book {
  id              String       @id @default(cuid())
  userId          String
  title           String
  author          String?
  yearBucket      Int?
  currentPage     Int?
  totalPages      Int?
  rating          Int?
  status          BookStatus   @default(TO_READ)
  startedAt       DateTime?
  finishedAt      DateTime?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs            BookLog[]

  @@index([userId, status])
  @@index([userId, yearBucket])
}

model BookLog {
  id              String       @id @default(cuid())
  userId          String
  bookId          String
  status          BookStatus
  currentPage     Int?
  notes           String?
  createdAt       DateTime     @default(now())
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  book            Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Movie {
  id              String       @id @default(cuid())
  userId          String
  title           String
  genre           String?
  releaseYear     Int?
  watchedAt       DateTime?
  rating          Int?
  status          MovieStatus  @default(TO_WATCH)
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs            MovieLog[]

  @@index([userId, status])
}

model MovieLog {
  id              String       @id @default(cuid())
  userId          String
  movieId         String
  status          MovieStatus
  rating          Int?
  notes           String?
  createdAt       DateTime     @default(now())
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie           Movie        @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model WaterGoal {
  id              String       @id @default(cuid())
  userId          String       @unique
  dailyGoalMl     Int
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WaterLog {
  id              String       @id @default(cuid())
  userId          String
  amountMl        Int
  occurredAt      DateTime
  createdAt       DateTime     @default(now())
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
}

model Appointment {
  id              String             @id @default(cuid())
  userId          String
  title           String
  description     String?
  startsAt        DateTime
  endsAt          DateTime?
  location        String?
  meetingUrl      String?
  status          AppointmentStatus  @default(SCHEDULED)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startsAt])
}

model Reminder {
  id              String          @id @default(cuid())
  userId          String
  title           String
  description     String?
  dueAt           DateTime?
  priority        Priority        @default(MEDIUM)
  recurrenceRule  String?
  status          ReminderStatus  @default(PENDING)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, dueAt])
}

model Medication {
  id              String                   @id @default(cuid())
  userId          String
  name            String
  dosage          String?
  instructions    String?
  frequencyType   MedicationFrequencyType  @default(DAILY)
  startDate       DateTime?
  endDate         DateTime?
  isActive        Boolean                  @default(true)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules       MedicationSchedule[]
  logs            MedicationLog[]

  @@index([userId, isActive])
}

model MedicationSchedule {
  id              String       @id @default(cuid())
  medicationId    String
  timeLabel       String
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  medication      Medication   @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  logs            MedicationLog[]
}

model MedicationLog {
  id                   String              @id @default(cuid())
  userId               String
  medicationId         String
  medicationScheduleId String?
  occurredAt           DateTime
  taken                Boolean             @default(true)
  notes                String?
  createdAt            DateTime            @default(now())
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  medication           Medication          @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  medicationSchedule   MedicationSchedule? @relation(fields: [medicationScheduleId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
}

model Exam {
  id              String       @id @default(cuid())
  userId          String
  name            String
  category        String?
  notes           String?
  recurrenceDays  Int?
  currentStatus   ExamStatus   @default(PLANNED)
  scheduledAt     DateTime?
  performedAt     DateTime?
  reviewedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs            ExamLog[]
  files           ExamFile[]

  @@index([userId, currentStatus])
}

model ExamLog {
  id              String       @id @default(cuid())
  userId          String
  examId          String
  status          ExamStatus
  notes           String?
  occurredAt      DateTime
  createdAt       DateTime     @default(now())
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam            Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
}

model ExamFile {
  id              String       @id @default(cuid())
  userId          String
  examId          String
  fileName        String
  fileUrl         String
  mimeType        String?
  createdAt       DateTime     @default(now())
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam            Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
